# =========================
# Client (Vite)
# =========================
# OAuth portal base URL used by client login redirect.
VITE_OAUTH_PORTAL_URL=https://oauth.your-domain.com

# OAuth app/client ID registered in your OAuth portal.
VITE_APP_ID=your-app-id

# Google OAuth (direct integration fallback, used by /api/auth/google/start)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional explicit callback URL. If empty, server derives it from request host:
# https://your-domain/api/oauth/google/callback
GOOGLE_REDIRECT_URI=

# Optional analytics (only if you use Umami)
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# =========================
# Server
# =========================
# PostgreSQL connection string (Supabase direct connection example)
DATABASE_URL=postgresql://postgres:your-db-password@db.your-project-ref.supabase.co:5432/postgres?sslmode=require

# Supabase project URL and anon key (needed only if you use Supabase client/API)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=
# Optional but recommended for server uploads (bypasses anon RLS limitations)
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=permit-attachments

# Cookie/JWT signing secret (use a long random string)
JWT_SECRET=replace-with-a-long-random-secret

# OAuth API/server URL used by backend token/user-info exchange
OAUTH_SERVER_URL=https://oauth-api.your-domain.com

# Optional owner OpenID used by some admin/system operations
OWNER_OPEN_ID=

# Optional built-in forge API (if used in your deployment)
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# =========================
# Email Notifications (Gmail SMTP)
# =========================
# Gmail address to send notifications from
SMTP_USER=your-email@gmail.com
# Gmail App Password (NOT your regular password)
# Generate at: https://myaccount.google.com/apppasswords
SMTP_PASS=your-app-password
